# Пример окружения для docker-compose (прод).
# deploy.sh скопирует этот файл в .env при первом запуске.
# ВАЖНО: на сервере поменяй секреты (JWT_SECRET, ADMIN_PASSWORD, DB_PASSWORD)!

# --- Postgres / подключение бэкенда к БД ---
DB_USERNAME=app
DB_PASSWORD=app
DB_NAME=petstore

# --- Бэкенд ---
JWT_SECRET=change_me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# --- Веб (nginx). Порт, на котором сайт будет доступен снаружи ---
WEB_PORT=80
