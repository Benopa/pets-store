# Enforce LF line endings for all text files in the repo and working tree.
# Overrides core.autocrlf so Windows checkouts stay LF (keeps Prettier/ESLint happy).
* text=auto eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
